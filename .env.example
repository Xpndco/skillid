DATABASE_URL=postgres://user:pass@host/db
PORT=3000

# Shared HS256 secret with RealSkill (handoff JWT)
REALSKILL_JWT_SECRET=change-me-shared-with-realskill

# Separate secret for SkillID's own session cookie (HS256)
SESSION_SECRET=change-me-skillid-only

# Where to send unauthenticated users
REALSKILL_LOGIN_URL=https://possibletraining.com/account/login
REALSKILL_REACTIVATE_URL=https://possibletraining.com/pages/free-courses

# Public URL of this app (used in return_to links)
PUBLIC_BASE_URL=https://skillid.possibletraining.com

# Integration Hub (optional — without these, free-claim grants are mocked locally)
INTEGRATION_HUB_URL=
INTEGRATION_HUB_API_KEY=
